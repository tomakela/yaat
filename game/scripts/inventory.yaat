# game/scripts/inventory.yaat
# Inventory item behavior for shared item definitions.

object brass_key {
  name "Brass Key"
  sprite "inventory/icons/brass_key.bmp"

  on look {
    say player "A small brass key with worn teeth."  # @scripts.inventory.1
  }

  on use {
    say player "I should try this key on a lock."  # @scripts.inventory.2
  }
}
